@model T3_Montes_Martin.Models.Libro

@{
    ViewData["Title"] = "Baja de Libro";
}

<div class="container my-4" style="max-width: 550px;">
    <div class="card border-0 shadow-sm border-top border-4 border-danger">
        <div class="card-body p-4">
            <h4 class="card-title text-danger fw-bold mb-3">¿Eliminar este registro?</h4>

            <div class="alert alert-danger p-2 small">
                Atención: Al confirmar, este libro se borrará de forma permanente de la base de datos.
            </div>

            <div class="mb-4 bg-light p-3 rounded border small">
                <div class="row mb-2">
                    <div class="col-4 fw-bold text-secondary">ID Registro:</div>
                    <div class="col-8">@Model.Id</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold text-secondary">Título:</div>
                    <div class="col-8 fw-bold">@Model.Titulo</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold text-secondary">Autor:</div>
                    <div class="col-8">@Model.Autor</div>
                </div>
                <div class="row">
                    <div class="col-4 fw-bold text-secondary">Editorial:</div>
                    <div class="col-8">@Model.Editorial</div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-light border px-4">Cancelar</a>
                    <button type="submit" class="btn btn-danger px-4 fw-bold">Sí, Eliminar</button>
                </div>
            </form>
        </div>
    </div>
</div>