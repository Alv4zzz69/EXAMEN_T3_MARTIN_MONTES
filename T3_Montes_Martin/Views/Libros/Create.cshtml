@model T3_Montes_Martin.Models.Libro

@{
    ViewData["Title"] = "Nuevo Libro";
}

<div class="container my-4" style="max-width: 650px;">
    <div class="card border-0 shadow-sm border-top border-4 border-success">
        <div class="card-body p-4">
            <h3 class="card-title text-success fw-bold mb-1">Registrar Libro</h3>
            <p class="text-muted small mb-4">Complete los campos obligatorios para guardar en SQL Server</p>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label fw-semibold text-secondary">Título:</label>
                    <input asp-for="Titulo" class="form-control" placeholder="Ingrese el nombre del libro" />
                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Autor" class="form-label fw-semibold text-secondary">Autor:</label>
                    <input asp-for="Autor" class="form-control" placeholder="Nombre completo del autor" />
                    <span asp-validation-for="Autor" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Tema" class="form-label fw-semibold text-secondary">Tema / Género:</label>
                        <input asp-for="Tema" class="form-control" />
                        <span asp-validation-for="Tema" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Editorial" class="form-label fw-semibold text-secondary">Editorial:</label>
                        <input asp-for="Editorial" class="form-control" />
                        <span asp-validation-for="Editorial" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="AnioPublicacion" class="form-label fw-semibold text-secondary">Año:</label>
                        <input asp-for="AnioPublicacion" type="number" class="form-control text-center" />
                        <span asp-validation-for="AnioPublicacion" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Paginas" class="form-label fw-semibold text-secondary">Páginas:</label>
                        <input asp-for="Paginas" type="number" class="form-control text-center" />
                        <span asp-validation-for="Paginas" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Copias" class="form-label fw-semibold text-secondary">Copias:</label>
                        <input asp-for="Copias" type="number" class="form-control text-center" />
                        <span asp-validation-for="Copias" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="Categoria" class="form-label fw-semibold text-secondary">Categoría:</label>
                        <input asp-for="Categoria" class="form-control" />
                        <span asp-validation-for="Categoria" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label asp-for="Material" class="form-label fw-semibold text-secondary">Material:</label>
                        <input asp-for="Material" class="form-control" />
                        <span asp-validation-for="Material" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a asp-action="Index" class="btn btn-light border px-4">Volver</a>
                    <button type="submit" class="btn btn-success px-4 fw-bold">Guardar Libro</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
 }