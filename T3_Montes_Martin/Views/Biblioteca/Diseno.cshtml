@{
    ViewData["Title"] = "Libros de Diseño de Software";
}

<div class="container my-4">
    <div class="p-4 mb-4 bg-secondary text-white rounded shadow-sm">
        <h1 class="display-5 fw-bold">Especialidad: Diseño de Software</h1>
        <p class="lead">Aprende sobre patrones de diseño, principios SOLID y cómo estructurar código limpio y reutilizable.</p>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <img src="/Fotos/imagendiseño1.jpg" class="card-img-top" alt="Clean Code" style="height: 350px; object-fit: contain; background: #f8f9fa; padding: 15px;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Clean Code: A Handbook of Agile Software Craftsmanship</h5>
                    <p class="card-text text-muted"><strong>Autor:</strong> Robert C. Martin (Uncle Bob) | <strong>Editorial:</strong> Prentice Hall</p>
                    <p class="card-text">El libro definitivo sobre cómo escribir código limpio, legible y profesional. Introduce conceptos clave sobre nombres de variables, funciones óptimas, manejo de errores y refactorización.</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <img src="/Fotos/imagendiseño2.jpg" class="card-img-top" alt="Design Patterns" style="height: 350px; object-fit: contain; background: #f8f9fa; padding: 15px;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Design Patterns (Gang of Four)</h5>
                    <p class="card-text text-muted"><strong>Autor:</strong> Erich Gamma, Richard Helm, Ralph Johnson, John Vlissides</p>
                    <p class="card-text">La biblia de la programación orientada a objetos. Contiene las soluciones estándar a los problemas de diseño de software más comunes mediante 23 patrones (Creacionales, Estructurales y de Comportamiento).</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">Video Destacado: Introducción a los Patrones de Diseño</h4>
        </div>
        <div class="card-body text-center">
            <div class="ratio ratio-16x9" style="max-width: 800px; margin: 0 auto;">
                <video controls preload="auto">
                    <source src="/Videos/videodiseño.mp4" type="video/mp4">
                    Tu navegador no soporta la reproducción de este video local.
                </video>
            </div>
        </div>
    </div>
</div>